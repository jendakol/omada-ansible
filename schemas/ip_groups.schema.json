{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IP Groups Configuration",
  "description": "Schema for IP address groups used in firewall rules",
  "type": "object",
  "required": ["ip_groups"],
  "properties": {
    "ip_groups": {
      "type": "array",
      "description": "List of IP address groups",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Group name"
          },
          "description": {
            "type": "string",
            "description": "Group description"
          },
          "devices": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "description": "Device name (from infra_devices.yml)"
            },
            "description": "List of device names to include (RECOMMENDED) - IPs are auto-resolved"
          },
          "addresses": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])/(\\d|[12]\\d|3[012])$",
              "description": "IP address in CIDR notation (e.g., 192.168.10.10/32)"
            },
            "description": "List of IP addresses/ranges in CIDR notation (LEGACY or for external IPs)"
          },
          "ipv6_addresses": {
            "type": "array",
            "items": {
              "type": "string",
              "description": "IPv6 address in CIDR notation"
            },
            "description": "List of IPv6 addresses/ranges (optional)"
          },
          "ip_list": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["ip", "mask"],
              "properties": {
                "ip": {
                  "type": "string",
                  "description": "IP address"
                },
                "mask": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 32,
                  "description": "Subnet mask"
                },
                "description": {
                  "type": "string",
                  "description": "IP description"
                }
              }
            },
            "description": "Detailed IP list with mask and description (advanced)"
          }
        },
        "anyOf": [
          {"required": ["devices"]},
          {"required": ["addresses"]},
          {"required": ["ipv6_addresses"]},
          {"required": ["ip_list"]}
        ]
      }
    }
  }
}
