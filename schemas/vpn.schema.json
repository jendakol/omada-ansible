{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VPN Configuration",
  "description": "Schema for WireGuard VPN settings",
  "type": "object",
  "required": ["wireguard"],
  "properties": {
    "wireguard": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable WireGuard VPN"
        },
        "listen_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535,
          "default": 51820,
          "description": "UDP port for WireGuard"
        },
        "subnet": {
          "type": "string",
          "pattern": "^(([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9]{2}|2[0-4][0-9]|25[0-5])/(\\d|[1-2]\\d|3[0-2])$",
          "description": "VPN subnet in CIDR notation"
        },
        "peers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "public_key", "allowed_ips"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1,
                "description": "Peer name"
              },
              "public_key": {
                "type": "string",
                "description": "WireGuard public key (use Ansible Vault)"
              },
              "allowed_ips": {
                "type": "string",
                "description": "IP address assigned to peer"
              },
              "keepalive": {
                "type": "integer",
                "minimum": 0,
                "description": "Keepalive interval in seconds"
              }
            }
          },
          "description": "List of VPN peers"
        }
      }
    }
  }
}
