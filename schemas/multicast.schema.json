{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Multicast Configuration",
  "description": "Schema for mDNS/multicast forwarding",
  "type": "object",
  "required": ["multicast_forwarding"],
  "properties": {
    "multicast_forwarding": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable multicast forwarding"
        },
        "service_networks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Networks where services are located"
        },
        "client_networks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Networks where clients are located"
        }
      }
    }
  }
}
